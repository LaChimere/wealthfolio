{
  "name": "wealthfolio-app",
  "private": true,
  "version": "3.4.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "apps/frontend",
    "apps/electron",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/frontend dev",
    "dev:tauri": "bun run --cwd apps/frontend dev:tauri",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "dev:addons": "bun run --cwd apps/frontend dev:addons",
    "dev:web": "bun run scripts/dev-web.mjs",
    "dev:web:log": "bun run scripts/dev-web.mjs --file-log",
    "build": "bun run --cwd apps/frontend build",
    "build:tauri": "bun run --cwd apps/frontend build:tauri",
    "build:electron": "bun run --cwd apps/frontend build:electron && bun run --cwd apps/electron build && bun run --cwd apps/electron stage:renderer",
    "build:electron:sidecar": "bun run scripts/build-electron-sidecar.mjs",
    "package:electron": "bun run build:electron && bun run build:electron:sidecar && bun run --cwd apps/electron dist",
    "build:types": "bun run --workspaces --if-present build:types",
    "biome:ci": "biome ci package.json tsconfig.json tsconfig.base.json tsconfig.node.json tsconfig.test.json apps/frontend/package.json apps/frontend/tsconfig.electron.json apps/electron/package.json apps/electron/tsconfig.json packages/addon-dev-tools/package.json packages/addon-sdk/package.json packages/ui/package.json --formatter-enabled=false --assist-enabled=false",
    "biome:lint": "biome lint package.json tsconfig.json tsconfig.base.json tsconfig.node.json tsconfig.test.json apps/frontend/package.json apps/frontend/tsconfig.electron.json apps/electron/package.json apps/electron/tsconfig.json packages/addon-dev-tools/package.json packages/addon-sdk/package.json packages/ui/package.json",
    "hooks:install": "lefthook install",
    "hooks:run": "lefthook run pre-commit --force",
    "preview": "bun run --cwd apps/frontend preview",
    "tauri": "tauri",
    "test": "bun run --cwd apps/frontend test",
    "test:electron": "bun run --cwd apps/electron test",
    "test:watch": "bun run --cwd apps/frontend test:watch",
    "test:ui": "bun run --cwd apps/frontend test:ui",
    "test:coverage": "bun run --cwd apps/frontend test:coverage",
    "test:e2e": "bun run scripts/run-e2e.mjs",
    "test:e2e:ui": "bun run scripts/run-e2e.mjs --ui",
    "lint": "bun run --workspaces --if-present lint",
    "lint:fix": "bun run --workspaces --if-present lint:fix",
    "lint:quiet": "bun run --workspaces --if-present lint:quiet",
    "lint:root": "bun run --cwd apps/frontend lint",
    "format": "prettier --write . && bun run --workspaces --if-present format",
    "format:check": "prettier --check . && bun run --workspaces --if-present format:check",
    "tsc": "tsc -b",
    "type-check": "bun run build:types && bun run --workspaces --if-present type-check",
    "type-check:root": "bun run --cwd apps/frontend type-check",
    "check": "bun run biome:ci && bun run format:check && bun run lint:quiet && bun run type-check",
    "publish:sdk": "cd packages/addon-sdk && npm publish --access public",
    "publish:ui": "cd packages/ui && npm publish --access public",
    "publish:addon-dev-tools": "cd packages/addon-dev-tools && npm publish --access public",
    "addon:create": "bun run --cwd packages/addon-dev-tools cli.js create",
    "addon:dev": "bun run --cwd packages/addon-dev-tools dev-server.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@tauri-apps/cli": "^2.11.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "overrides": {
    "ip-address": "10.1.1"
  }
}
