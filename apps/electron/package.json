{
  "name": "@wealthfolio/electron",
  "private": true,
  "description": "Wealthfolio Electron desktop shell.",
  "author": "Teymz Inc.",
  "version": "3.4.0",
  "type": "module",
  "main": "dist/main/index.js",
  "exports": {
    "./shared/ipc": "./src/shared/ipc.ts"
  },
  "scripts": {
    "start": "electron .",
    "clean": "rm -rf dist",
    "build": "bun run clean && bun run build:main && bun run build:preload",
    "build:main": "bun build src/main/index.ts --target=node --format=esm --outdir=dist/main --sourcemap=external --external electron",
    "build:preload": "bun build src/preload/index.ts --target=node --format=cjs --outfile=dist/preload/index.cjs --sourcemap=inline --external electron",
    "stage:renderer": "node ../../scripts/stage-electron-renderer.mjs",
    "build:types": "tsc -p tsconfig.json",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "bun test src/**/*.test.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^24.10.13",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
